# Default settings for the manual distributed MiniSQL test scripts.
# Scripts source this file after defining ROOT_DIR.

: "${RUNTIME_DIR:=$ROOT_DIR/tmp}"
: "${CLUSTER_NAME:=dis-minisql-manual-e2e}"

: "${ZK_HOST:=127.0.0.1}"
: "${ZK_PORT:=12181}"
: "${COORD_HOST:=127.0.0.1}"
: "${COORD_PORT:=18080}"

: "${NODE_A_HOST:=127.0.0.1}"
: "${NODE_A_PORT:=19001}"
: "${NODE_B_HOST:=127.0.0.1}"
: "${NODE_B_PORT:=19002}"
: "${NODE_C_HOST:=127.0.0.1}"
: "${NODE_C_PORT:=19003}"
: "${NODE_D_HOST:=127.0.0.1}"
: "${NODE_D_PORT:=19004}"

: "${SESSION_TIMEOUT_MS:=8000}"
: "${SHARD_COUNT:=3}"
: "${REPLICATION_FACTOR:=3}"
: "${DEFAULT_DATABASE:=dist}"

: "${MINISQL_BINARY:=$ROOT_DIR/minisql/build/bin/main}"
: "${JAR_PATH:=$ROOT_DIR/dis-minisql/target/dis-minisql-1.0.0.jar}"
