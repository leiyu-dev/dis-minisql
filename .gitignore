# Editor / language servers
.ccls-cache/

# Maven
**/target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar

# IDE
.idea/
*.iml
*.ipr
*.iws
.project
.classpath
.settings/
.vscode/
*.code-workspace

# OS
.DS_Store
Thumbs.db

# Logs & temp
*.log
*.tmp
*.swp
*~

# ---- dis-minisql runtime (DataNode / ZK / scripts) ----
/data/
/logs/
/zkdata/

# ZooKeeper 发行版：只保留 conf/（如 zoo.cfg 示例），其余 bin/lib/docs 等不入库。
# 注意：不能写 /apache-zookeeper-*-bin/ 整目录忽略后再 !conf，父目录被忽略时子路径无法被重新包含。
/apache-zookeeper-*-bin/*
!/apache-zookeeper-*-bin/conf/
!/apache-zookeeper-*-bin/conf/**
/apache-zookeeper*.tar.gz
# MiniSQL C++ build tree (also see minisql/.gitignore)
minisql/build/
minisql/cmake-build-*/

# JVM crash / heap dumps
hs_err_pid*.log
replay_pid*.log
*.hprof

# Core dumps (minisql segfault etc.)
core
core.*
